{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022"
  },
  "include": [
    "src/lib/job-assistant/__tests__/*.test.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}